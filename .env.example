# Sqliqs environment — copy to .env.local and fill in.
# These power the public Playground only. User projects supply their own
# connection strings and model keys through the UI (stored in the browser).

# Connection string for the Playground's hosted sample database.
# Use a READ-ONLY role at runtime.
DATABASE_URL="postgres://readonly_user:password@host/dbname"

# Owner/write role used by `bun seed`. Falls back to DATABASE_URL if unset.
SEED_DATABASE_URL="postgres://owner_user:password@host/dbname"

# Key for the built-in free model the Playground uses.
OPENROUTER_API_KEY="sk-or-..."

# Optional: override the default free model id.
# OPENROUTER_DEFAULT_MODEL="..."
